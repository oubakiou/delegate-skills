#!/bin/bash
# pre-commit hook: build / lint / format / type / test を走らせ、いずれか失敗したら commit を block する。
# set -e なしだと vp check --fix が非 0 で抜けても後続コマンドに進んでしまい、最後の vp test が
# pass すると hook 全体が exit 0 になって commit が通ってしまう (sort-imports などの --fix 対象外
# ルールが見落とされる経路)。set -e で最初の失敗で止める。
set -e

diff_before=$(git diff --name-only | sort)

# 1. 編集者が generated コピー (skills/*/scripts/{sanitize,codex-jsonl}.ts) を
#    直接編集していないかの早期検出。手順誤りを最初に教える。
npm run sync-shared:check --silent

# 2. format / lint の自動修正
vp check --fix

# 3. vp check --fix が shared/ の正本を書き換えた場合、コピー側へ再同期する。
#    drift があれば sync-shared が黙ってコピーを更新する。
npm run sync-shared --silent

# git commit が index.lock を保持しているため、hook 内では git add しない。
# hook がワークツリーを変更した場合は利用者に確認と再ステージを促す。
diff_after=$(git diff --name-only | sort)
if [ "$diff_before" != "$diff_after" ]; then
  hook_changed=$(comm -13 <(echo "$diff_before") <(echo "$diff_after"))
  echo ""
  echo "error: pre-commit hook が以下のファイルを変更しました:"
  echo "$hook_changed"
  echo ""
  echo "変更を確認し、ステージしてから再度コミットしてください:"
  echo "  git add -u && git commit"
  exit 1
fi

# 4. 最終ドリフト検証 (fail-closed)。
#    手順 1 と 3 を経ても何らかの理由でズレが残っている場合に commit を止める保険。
npm run sync-shared:check --silent

vp test

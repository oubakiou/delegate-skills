{
  "name": "delegate-skills",
  "author": "oubakiou",
  "type": "module",
  "scripts": {
    "build": "vp build --config vite.cli.config.ts",
    "build:check": "bash scripts/check-cli-build.sh",
    "metrics:baseline:check": "bash scripts/check-metrics-baseline.sh",
    "metrics:cost-check": "bash scripts/run-metrics-fixtures.sh --json | node scripts/evaluate-cost-fixtures.ts",
    "metrics:fixtures": "bash scripts/run-metrics-fixtures.sh",
    "metrics:summarize": "node scripts/summarize-metrics.ts",
    "sync-shared": "node scripts/sync-shared.ts",
    "sync-shared:check": "node scripts/sync-shared.ts --check",
    "test": "node scripts/test-execution-capability.ts && vp test"
  },
  "devDependencies": {
    "@anthropic-ai/claude-code": "^2.1.80",
    "@openai/codex": "0.x",
    "@types/node": "^24.0.0",
    "md2idx": "^0.3.0",
    "mdxg-redline": "^0.1.3",
    "oxlint-tsgolint": "0.x",
    "typescript": "^6.0.2",
    "typescript-language-server": "^5.1.3",
    "vite-plus": "^0.x",
    "vitest": "^4.1.1"
  }
}
